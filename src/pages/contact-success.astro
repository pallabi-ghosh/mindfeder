---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message sent — Mindfeder" description="Your message has been sent successfully.">
  <section class="mx-auto flex min-h-[70vh] max-w-3xl items-center px-5 py-20">
    <div class="w-full rounded-2xl border border-black/5 bg-cream-soft p-8 text-center shadow-sm md:p-10">
      <p class="text-sm font-medium uppercase tracking-[0.25em] text-forest-deep">Thank you</p>
      <h1 class="mt-3 font-display text-3xl text-forest-deep md:text-4xl">Your message has been sent.</h1>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink/85">
        We appreciate your enquiry and will get back to you shortly. If you need an immediate response, please call or email us directly.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/" class="rounded-md bg-forest-deep px-6 py-3 text-sm font-medium text-cream transition hover:bg-forest">Back to home</a>
        <a href="/contact" class="rounded-md border border-black/10 px-6 py-3 text-sm font-medium text-forest-deep transition hover:bg-white">Send another message</a>
      </div>
    </div>
  </section>
</Layout>
