---
import Layout from '../layouts/Layout.astro';
import Sprig from '../components/Sprig.astro';
import { Icon } from 'astro-icon/components';

const experiences = [
  { icon: 'lucide:palette', title: 'Art-based & interactive group activities' },
  { icon: 'lucide:compass', title: 'Self-exploration circles' },
  { icon: 'lucide:sparkles', title: 'Creative expression sessions' },
  { icon: 'lucide:wind', title: 'Relaxation and grounding experiences' },
  { icon: 'lucide:users-round', title: 'Community connection spaces' },
];
---

<Layout title="Events & Experiences — Mindfeder" description="Curated events and experiences designed for reflection, connection and emotional ease.">
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center md:py-20">
      <p class="text-sm font-medium uppercase tracking-widest text-sage">Events & Experiences</p>
      <h1 class="mt-3 font-display text-4xl text-forest-deep md:text-5xl">Spaces for presence, expression &amp; ease.</h1>
      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-muted">
        Discover curated events and experiences designed for reflection, connection and emotional ease.
        These are safe, non-judgmental spaces that focus on presence and expression — never performance or perfection.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-5 py-16">
    <h2 class="font-display text-2xl text-forest-deep">What people experience here</h2>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {experiences.map((e) => (
        <div class="relative flex items-center gap-4 overflow-hidden rounded-xl border border-black/5 bg-cream-soft p-5">
          <Sprig class="pointer-events-none absolute -bottom-3 -right-3 h-16 w-16 text-sage/25" />
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-cream text-forest">
            <Icon name={e.icon} class="h-5 w-5" />
          </div>
          <p class="relative text-sm leading-snug text-ink/85">{e.title}</p>
        </div>
      ))}
    </div>

    <!-- Upcoming placeholder -->
    <div class="mt-14 rounded-2xl bg-cream px-6 py-10 text-center">
      <h2 class="font-display text-2xl text-forest-deep">Upcoming sessions</h2>
      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-muted">
        New experiences are announced here regularly. Choose what resonates with you and book your seat effortlessly.
      </p>
      <a href="/contact" class="mt-6 inline-block rounded-md bg-forest-deep px-6 py-3 text-sm font-medium text-cream transition hover:bg-forest">
        Enquire about upcoming events
      </a>
    </div>
  </div>
</Layout>
