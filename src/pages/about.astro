---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const facts = [
  { icon: 'lucide:calendar-clock', label: '6+ Years Experience' },
  { icon: 'lucide:building', label: 'Clinical · School · Corporate Exposure' },
  { icon: 'lucide:users', label: 'One-to-One & Group Facilitation' },
  { icon: 'lucide:heart', label: 'For Individuals, Teams & Communities' },
];

const approaches = [
  'Cognitive Behavioural Therapy (CBT)',
  'Acceptance and Commitment Therapy (ACT)',
  'Mindfulness practices',
  'Relaxation techniques',
];
---

<Layout title="About — Mindfeder" description="Meet Kumarica Dutta, a psychology practitioner with 6+ years of experience across mental health, counselling and wellbeing-focused work.">
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center md:py-20">
      <p class="text-sm font-medium uppercase tracking-widest text-sage">About Mindfeder</p>
      <h1 class="mt-3 font-display text-4xl text-forest-deep md:text-5xl">Rooted in psychology. Driven by purpose.</h1>
      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-muted">
        Mindfeder is a psychology-informed space for emotional wellbeing and growth — created to help
        people make sense of their experiences, navigate challenges, and move forward with clarity and intention.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-5 py-16">
    <!-- Practitioner -->
    <div class="grid gap-8 md:grid-cols-[260px_1fr] md:items-start">
      <div class="flex aspect-[4/5] items-center justify-center rounded-2xl bg-sage/20 text-center">
        <p class="px-6 font-display text-lg italic text-forest/50">Photo of<br />Kumarica Dutta</p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-forest-deep md:text-3xl">Kumarica Dutta</h2>
        <p class="text-sm font-medium text-sage">Counselling Psychologist</p>
        <div class="mt-5 space-y-4 text-base leading-relaxed text-muted">
          <p>
            I’m a psychology practitioner with 6+ years of experience across mental health, counselling
            and wellbeing-focused work in diverse settings — including clinical practice, hospitals,
            schools and corporate wellbeing environments. I’ve worked with individuals across different
            age groups and psychological needs, engaging with a wide range of emotional and behavioural concerns.
          </p>
          <p>
            I hold a master’s degree in Applied Psychology, with a specialization in Stress and Crisis Management.
          </p>
        </div>
      </div>
    </div>

    <!-- Approach -->
    <div class="mt-14 rounded-2xl bg-cream p-8">
      <h3 class="font-display text-xl text-forest-deep">My approach</h3>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted">
        My work is grounded in evidence-based psychological approaches, integrated into counselling and
        experiential formats to support emotional awareness, resilience and practical everyday wellbeing.
      </p>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {approaches.map((a) => (
          <li class="flex items-center gap-2.5 text-sm text-ink/85">
            <Icon name="lucide:check" class="h-4 w-4 shrink-0 text-forest" />{a}
          </li>
        ))}
      </ul>
    </div>

    <!-- Facts -->
    <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-4">
      {facts.map((f) => (
        <div class="text-center">
          <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-full bg-cream text-forest">
            <Icon name={f.icon} class="h-5 w-5" />
          </div>
          <p class="text-sm leading-snug text-ink/80">{f.label}</p>
        </div>
      ))}
    </div>

    <!-- Intention -->
    <div class="mt-14 text-center">
      <p class="mx-auto max-w-2xl font-display text-xl italic leading-relaxed text-forest/80">
        “The intention behind Mindfeder is to create safe, reflective spaces where individuals, organisations
        and communities can better understand their inner experiences, navigate challenges, and move forward
        with clarity and intention.”
      </p>
    </div>
  </div>
</Layout>
