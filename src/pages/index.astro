---
import Layout from '../layouts/Layout.astro';
import Sprig from '../components/Sprig.astro';
import { Icon } from 'astro-icon/components';

const pillars = [
  { label: 'Evidence-Based Approach', icon: 'lucide:brain' },
  { label: 'Safe & Inclusive Space', icon: 'lucide:shield-check' },
  { label: 'Personalised Interventions', icon: 'lucide:user-round' },
  { label: 'Mindful & Holistic', icon: 'lucide:sparkles' },
];

const cards = [
  { icon: 'lucide:heart-handshake', title: 'Individual Counseling', body: 'One-to-one sessions for emotional well-being, self-awareness, relationships, anxiety, stress & more.', href: '/services#individual-counselling' },
  { icon: 'lucide:building-2', title: 'Corporate Mental Health Programs', body: 'Workplace well-being solutions including EAP, leadership training, team workshops and more.', href: '/services#corporate' },
  { icon: 'lucide:book-open', title: 'Psychoeducational Workshops', body: 'Interactive sessions on mental health, emotions, resilience, burnout, communication and personal growth.', href: '/services#workshops' },
  { icon: 'lucide:users-round', title: 'Curated Experiences & Community Spaces', body: 'Art-based, experiential events and community circles to explore well-being, creativity, connection and inner growth.', href: '/services#community' },
];
---

<Layout>
  <!-- HERO -->
  <section class="bg-cream">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 md:grid-cols-2 md:py-24">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-sage">Heal. Reflect. Grow.</p>
        <h1 class="mt-4 font-display text-4xl leading-[1.1] text-forest-deep sm:text-5xl lg:text-6xl">
          A space for healing, reflection <span class="italic text-forest">&amp; meaningful change.</span>
        </h1>
        <p class="mt-6 max-w-md text-base leading-relaxed text-muted">
          Mindfeder is a psychology-based practice offering counselling, corporate programs, workshops and curated experiences for individuals, teams and communities.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/services" class="rounded-md bg-forest-deep px-6 py-3 text-center text-sm font-medium text-cream transition hover:bg-forest">Explore Services</a>
          <a href="/contact" class="rounded-md border border-forest/30 px-6 py-3 text-center text-sm font-medium text-forest transition hover:bg-cream-soft">Book a Session</a>
        </div>
      </div>
      <div class="relative aspect-[4/5] overflow-hidden rounded-2xl bg-sage/20 md:aspect-square">
        <img src="/intro.png" alt="Mindfeder introduction" class="h-full w-full object-cover" />
      </div>
    </div>
    <div class="mx-auto max-w-6xl px-5 pb-14">
      <div class="grid grid-cols-2 gap-6 border-t border-black/5 pt-8 md:grid-cols-4">
        {pillars.map((p) => (
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-full bg-cream-soft text-forest">
              <Icon name={p.icon} class="h-5 w-5" />
            </div>
            <p class="text-sm text-ink/80">{p.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OUR SERVICES -->
  <section class="mx-auto max-w-6xl px-5 py-20 text-center">
    <p class="text-sm font-medium uppercase tracking-widest text-sage">What we offer</p>
    <h2 class="mt-3 font-display text-3xl text-forest-deep md:text-4xl">Our Services</h2>
    <div class="mt-12 grid gap-5 text-left sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((c) => (
        <a href={c.href} class="group relative overflow-hidden rounded-xl border border-black/5 bg-cream-soft p-6 transition hover:border-forest/20 hover:shadow-sm">
          <Sprig class="pointer-events-none absolute -bottom-2 -right-2 h-20 w-20 text-sage/30" />
          <div class="relative">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-full bg-cream text-forest">
              <Icon name={c.icon} class="h-5 w-5" />
            </div>
            <h3 class="font-display text-xl leading-snug text-forest-deep">{c.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{c.body}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm text-forest/80 transition-all group-hover:gap-2">
              Learn more <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- JOURNAL FEATURE -->
  <section class="bg-cream">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 md:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-sage">New</p>
        <h2 class="mt-3 font-display text-3xl text-forest-deep md:text-4xl">The Corporate Survival Journal</h2>
        <p class="mt-4 max-w-md text-base leading-relaxed text-muted">
          A reflective companion for navigating workplace dynamics, burnout, self-awareness and professional growth.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/shop" class="rounded-md bg-forest-deep px-6 py-3 text-center text-sm font-medium text-cream transition hover:bg-forest">Shop Now</a>
          <a href="/shop#about-journal" class="rounded-md border border-forest/30 px-6 py-3 text-center text-sm font-medium text-forest transition hover:bg-cream-soft">Learn More</a>
        </div>
      </div>
      <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-forest/10">
        <Sprig class="absolute right-4 top-4 h-16 w-16 text-forest/20" />
        <img src="/journal.png" alt="Corporate Survival Journal" class="absolute inset-0 h-full w-full object-cover object-[85%_50%]" />
      </div>
    </div>
  </section>
</Layout>
