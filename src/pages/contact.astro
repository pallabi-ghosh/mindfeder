---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const reasons = [
  'Individual counselling inquiries',
  'Corporate mental health programs',
  'Workshops and curated experiences',
  'Journal or shop-related questions',
];
---

<Layout title="Contact — Mindfeder" description="Get in touch with Mindfeder for counselling, corporate programs, workshops, experiences or journal enquiries.">
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center md:py-20">
      <p class="text-sm font-medium uppercase tracking-widest text-sage">Let’s work together</p>
      <h1 class="mt-3 font-display text-4xl text-forest-deep md:text-5xl">We’d love to hear from you.</h1>
      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-muted">
        Whether you’re looking for support, collaboration, or more information about sessions and programs,
        feel free to reach out.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-5 py-16">
    <div class="grid gap-12 md:grid-cols-[1fr_1.4fr]">
      <!-- Left: contact info -->
      <div>
        <h2 class="font-display text-xl text-forest-deep">You can contact us for</h2>
        <ul class="mt-4 space-y-2.5">
          {reasons.map((r) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-ink/85">
              <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-forest" />{r}
            </li>
          ))}
        </ul>
        <div class="mt-8 space-y-3 text-sm text-ink/85">
          <p class="flex items-center gap-2.5"><Icon name="lucide:mail" class="h-4 w-4 text-forest" /> Kumarica.dutta@gmail.com</p>
          <p class="flex items-center gap-2.5"><Icon name="lucide:phone" class="h-4 w-4 text-forest" /> +91 91632 98741</p>
        </div>
        <p class="mt-8 text-xs leading-relaxed text-muted">
          We aim to respond within 24–48 hours. Your details are used only to respond to your enquiry and are kept confidential.
        </p>
      </div>

      <!-- Right: form -->
      <div class="rounded-2xl border border-black/5 bg-cream-soft p-6 md:p-8">
        <p class="text-sm text-muted">Please fill out the form below and we’ll get back to you shortly.</p>
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="mt-6 space-y-5">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don’t fill this out: <input name="bot-field" /></label></p>

          <div>
            <label for="name" class="block text-sm font-medium text-ink/85">Full name</label>
            <input id="name" name="name" type="text" required class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest" />
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-sm font-medium text-ink/85">Email address</label>
              <input id="email" name="email" type="email" required class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-ink/85">Phone <span class="text-muted">(optional)</span></label>
              <input id="phone" name="phone" type="tel" class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest" />
            </div>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="interest" class="block text-sm font-medium text-ink/85">I am interested in</label>
              <select id="interest" name="interest" class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest">
                <option>Counselling</option>
                <option>Corporate</option>
                <option>Workshops</option>
                <option>Experiences</option>
                <option>Journal</option>
              </select>
            </div>
            <div>
              <label for="mode" class="block text-sm font-medium text-ink/85">Preferred mode</label>
              <select id="mode" name="mode" class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest">
                <option>Online</option>
                <option>Offline</option>
              </select>
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink/85">Message / brief requirement</label>
            <textarea id="message" name="message" rows="4" class="mt-1.5 w-full rounded-md border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-forest focus:ring-1 focus:ring-forest"></textarea>
          </div>
          <button type="submit" class="w-full rounded-md bg-forest-deep px-6 py-3 text-sm font-medium text-cream transition hover:bg-forest">Send message</button>
        </form>
      </div>
    </div>
  </div>
</Layout>
