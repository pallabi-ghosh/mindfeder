---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paytm Checkout — Mindfeder" description="Pay for the Mindfeder journal using Paytm.">
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center md:py-20">
      <p class="text-sm font-medium uppercase tracking-widest text-sage">Checkout</p>
      <h1 class="mt-3 font-display text-4xl text-forest-deep md:text-5xl">Pay for your journal</h1>
      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-muted">
        You can pay directly using Paytm. Once the payment link opens, complete the transaction in your Paytm app or browser.
      </p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a href="upi://pay?pa=kumarica.dutta@oksbi&pn=Mind%20Feed&tn=Corporate+Survival+Journal&am=1200&cu=INR" class="rounded-md bg-forest-deep px-6 py-3 text-center text-sm font-medium text-cream transition hover:bg-forest">Pay with Paytm UPI</a>
        <a href="intent://pay?pa=kumarica.dutta@oksbi&pn=Mind%20Feed&tn=Corporate+Survival+Journal&am=1200&cu=INR#Intent;scheme=upi;package=net.one97.paytm;end" class="rounded-md border border-black/5 bg-white px-6 py-3 text-center text-sm font-medium text-forest transition hover:bg-cream">Open in Paytm app</a>
      </div>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-muted">
        Note: UPI links only work if a UPI-compatible app is installed and your mobile browser supports custom UPI schemes. If the link does not open Paytm, try installing the Paytm app or using a different browser.
      </p>
    </div>
  </section>
</Layout>
