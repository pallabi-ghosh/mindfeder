---
const links = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Experiences', href: '/experiences' },
  { label: 'Shop', href: '/shop', badge: 'New' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-cream-soft/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <!-- Brand -->
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.png" alt="Mind Feed logo" class="h-10 w-auto" />
        <div class="flex flex-col">
          <span class="font-display text-xl font-semibold tracking-wide text-forest-deep">Mind Feed</span>
          <span class="text-xs uppercase tracking-[0.24em] text-muted">Mental health space</span>
        </div>
      </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a href={l.href} class="relative text-sm text-ink/80 transition hover:text-forest">
          {l.label}
          {l.badge && (
            <span class="absolute -top-3 -right-6 rounded-full bg-forest px-1.5 py-0.5 text-[9px] font-semibold uppercase text-cream">{l.badge}</span>
          )}
        </a>
      ))}
      <a href="/contact" class="rounded-md bg-forest-deep px-4 py-2 text-sm font-medium text-cream transition hover:bg-forest">Book a Session</a>
      <a href="https://share.google/wgDNXK8hG7LrvPNgA" target="_blank" rel="noopener noreferrer" class="rounded-md border border-forest/30 px-4 py-2 text-sm font-medium text-forest transition hover:bg-cream-soft">Leave a review</a>
    </nav>

    <!-- Mobile toggle -->
    <button id="navToggle" class="md:hidden" aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-forest-deep">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav panel -->
  <nav id="mobileNav" class="hidden border-t border-black/5 bg-cream-soft px-5 py-4 md:hidden">
    <ul class="flex flex-col gap-1">
      {links.map((l) => (
        <li>
          <a href={l.href} class="block rounded-md px-2 py-2.5 text-ink/85 transition hover:bg-cream hover:text-forest">
            {l.label}{l.badge && <span class="ml-2 text-xs text-sage">• {l.badge}</span>}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/contact" class="block rounded-md bg-forest-deep px-4 py-2.5 text-center font-medium text-cream">Book a Session</a>
      </li>
      <li>
        <a href="https://share.google/wgDNXK8hG7LrvPNgA" target="_blank" rel="noopener noreferrer" class="block rounded-md px-2 py-2.5 text-ink/85 transition hover:bg-cream hover:text-forest">Leave a review</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const panel = document.getElementById('mobileNav');
  toggle?.addEventListener('click', () => {
    const open = panel?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(open === false));
  });
</script>
